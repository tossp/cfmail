{
  "name": "cfmail",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "pnpm db:migrate && wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "hono": "^4.12.5",
    "postal-mime": "^2.7.3",
    "uuidv7": "^1.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260305.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.71.0"
  },
  "cloudflare": {
    "bindings": {
      "AUTH_TOKEN": {
        "description": "API 鉴权令牌，可通过 `openssl rand -hex 32` 生成"
      }
    }
  }
}
